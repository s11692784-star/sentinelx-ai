APP_NAME=SentinelX AI
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1

# Postgres on Render/Neon/Supabase, or sqlite for tiny demos
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/sentinelx

REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# REQUIRED — 64 hex chars (32 bytes) for AES-256-GCM
# openssl rand -hex 32
AES_MASTER_KEY=

# Comma-separated frontend origins (your Vercel URL)
CORS_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

GEMINI_API_KEY=
RATE_LIMIT_PER_MINUTE=120
SESSION_COOKIE_SECURE=true
FORCE_HTTPS=true
ALLOW_DEMO_SEED=false
